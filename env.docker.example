# Ubuntu / production Docker için kopyalayın: cp env.docker.example .env
# Değerleri kendi sunucu ve registry bilgilerinize göre düzenleyin.

# --- Veritabanı (postgres servisi) ---
DB_NAME=pricelist_app_3
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_PORT=55432

# --- Backend ---
BACKEND_PORT=3001
JWT_SECRET=change-me-minimum-32-characters-random-string
# Tarayıcıdan API'ye erişim: sunucu public URL (port 80 ise sadece origin)
CORS_ORIGIN=https://your-domain.com,http://your-server-ip
FRONTEND_URL=https://your-domain.com

# --- Frontend imajı build edilirken (opsiyonel; boş = nginx /api proxy ile relative URL) ---
# VITE_API_BASE_URL=

# --- Dışarı açılan HTTP portu (host) ---
FRONTEND_PORT=8081

# --- Registry'ye imaj göndermek için (docker compose push) ---
# Aşağıdakileri kendi hesabınıza göre doldurun; docker compose imaj adı olarak kullanır.
# DOCKER_USERNAME=onderxyilmaz
# IMAGE_TAG=v1.0.0
# BACKEND_IMAGE=docker.io/onderxyilmaz/pricelist-backend:${IMAGE_TAG:-latest}
# compose .env tek satır tercih eder; tam örnek:
# BACKEND_IMAGE=docker.io/myuser/pricelist-backend:v1.0.0
# FRONTEND_IMAGE=docker.io/myuser/pricelist-frontend:v1.0.0
