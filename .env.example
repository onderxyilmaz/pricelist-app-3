# ===========================================
# Docker Compose - Production (Karadağ Elektronik)
# Bu dosyayı .env olarak kopyalayıp değerleri güncelleyin.
# ===========================================

# Database
DB_NAME=pricelist_app_3
DB_USER=postgres
DB_PASSWORD=change-this-strong-password
DB_PORT=55432

# Backend
BACKEND_PORT=3001
JWT_SECRET=change-this-in-production-minimum-32-characters-strong-secret-key
CORS_ORIGIN=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80
FRONTEND_URL=http://localhost:80

# Frontend (Nginx reverse proxy kullanıldığında API aynı origin'den gider)
# Production: Boş bırakın (frontend /api ve /uploads'ı Nginx ile backend'e yönlendirir)
# Sadece frontend'i ayrı portta test ediyorsanız: http://localhost:3001
FRONTEND_PORT=80
VITE_API_BASE_URL=

# Not: Firmada tek sunucuda çalıştırıyorsanız CORS_ORIGIN ve FRONTEND_URL'i
# sunucu adresi ile güncelleyin, örn: https://pricelist.sirketadi.com

